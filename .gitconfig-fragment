# Git config fragment for repo-local pre-commit guards.
# Loaded via `git config --local --add include.path ../.gitconfig-fragment`
# on Git >= 2.54. `git hook list pre-commit` will then show every guard below.
[hook "secrets-scan"]
	event = pre-commit
	command = scripts/secrets-scan.sh
[hook "lint-staged"]
	event = pre-commit
	command = scripts/lint-staged.sh
