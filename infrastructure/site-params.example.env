# Per-site deploy parameters for the infrastructure/ and oauth-proxy/ stacks.
# Copy to site-params.env (gitignored), fill in the secrets, then before
# running any of the platform's deploy.sh scripts:
#   cp infrastructure/site-params.example.env infrastructure/site-params.env
#   # edit infrastructure/site-params.env with the real OAuth app id/secret
#   set -a; source infrastructure/site-params.env; set +a
# Only this .example template is committed; the filled site-params.env is
# gitignored so the GitHub OAuth client secret never lands in git.

# ── Required ────────────────────────────────────────────────────────────────
export GITHUB_REPO="jodidaniel.com"        # owner is GITHUB_ORG below
export APEX_DOMAIN="jodidaniel.com"         # production apex (no scheme)

# ── OAuth proxy (oauth-proxy/deploy.sh) ──────────────────────────────────────
export GITHUB_CLIENT_ID="xxxxxxxxxxxxxxxx"
export GITHUB_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export ALLOWED_ORIGINS="https://jodidaniel.com"
export STACK_NAME="jodidaniel-com-oauth-proxy"   # oauth-proxy stack/function name

# ── Optional (sensible defaults derive from APEX_DOMAIN) ─────────────────────
# export GITHUB_ORG="Adam-S-Daniel"
# export RESOURCE_PREFIX="jodidaniel-com"          # apex with dots->hyphens
# export AWS_REGION="us-east-1"
# export HOSTED_ZONE_ID="ZXXXXXXXXXXXXX"         # auto-detected from Route53 if unset
